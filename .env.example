# ─── GitHub App ───
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY_PATH=./github-app.pem
GITHUB_WEBHOOK_SECRET=

# ─── LLM Provider ───
# Options: "groq", "ollama"
LLM_PROVIDER=groq

# Groq (free hosted)
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-70b-versatile

# Ollama (self-hosted)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=deepseek-coder-v2

# ─── Review Settings ───
# Minimum severity to post as inline comment: critical, warning, suggestion
MIN_INLINE_SEVERITY=warning
# Max files to review per PR (0 = unlimited)
MAX_FILES_PER_REVIEW=50
# Max diff lines per file before chunking
MAX_DIFF_LINES_PER_FILE=500

# ─── Server ───
HOST=0.0.0.0
PORT=8080
DATABASE_URL=sqlite:///./data/reviews.db
LOG_LEVEL=INFO

# ─── Frontend ───
VITE_API_URL=http://localhost:8080
